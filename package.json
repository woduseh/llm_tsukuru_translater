{
  "name": "gemini-tsukuru-extractor",
  "version": "3.0.0",
  "description": "Tsukuru Extractor",
  "main": "main.js",
  "scripts": {
    "codepage": "chcp 65001",
    "start2": "electron . start",
    "start": "npm-run-all --parallel codepage start2",
    "build:ts": "tsc",
    "build:renderer": "esbuild src/html/main/renderer.js --bundle --outfile=src/html/main/renderer.bundle.js --format=iife --platform=browser",
    "prebuild": "tsc",
    "prestart": "npm run build:renderer",
    "build": "electron-builder --windows portable nsis:x64",
    "build2": "electron-builder --windows portable",
    "lint": "eslint \"src/**/*.ts\" \"main.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "author": "Jackdu",
  "license": "MIT",
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/aes-js": "^3.1.4",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.0",
    "@types/lodash": "^4.17.24",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "aes-js": "^3.1.2",
    "axios": "^1.13.6",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "encoding-japanese": "^2.2.0",
    "fast-csv": "^5.0.5",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.6",
    "iconv-lite": "^0.7.2",
    "js-yaml": "^4.1.0",
    "jsdom": "^28.1.0",
    "lodash": "^4.17.21",
    "open": "^8.4.0"
  },
  "build": {
    "productName": "Tsukuru Extractor",
    "appId": "net.electron.MVExtractor",
    "asar": true,
    "files": [
      "**/*",
      "!test/*",
      "!dist/*",
      "!addon/*",
      "!**/*.ts",
      "!**/*.d.ts"
    ],
    "extraResources": [],
    "protocols": {
      "name": "MVExtractor",
      "schemes": [
        "MVExtractor"
      ]
    },
    "win": {
      "target": [
        "zip",
        "nsis"
      ],
      "icon": "./res/icon.ico",
      "files": [
        "!gruntfile.js",
        "!README.md",
        "!notarize.js",
        "!.env",
        "!minify.js",
        "!.git/*",
        "!resources/mac/*"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "buildResources": "./resources/installer/",
      "output": "./dist/",
      "app": "./"
    }
  }
}
